if [ "${STATUS}" = "remove" ]; then
    if [ -f /usr/share/polkit-1/rules.d/esf-bluetooth.rules ]; then
        echo "Removing /usr/share/polkit-1/rules.d/kura-bluetooth.rules"
        rm -f /usr/share/polkit-1/rules.d/kura-bluetooth.rules
    fi
    BLUETOOTH_CONF_PATH=/etc/dbus-1/system.d/bluetooth.conf
    if [ ! -f "${BLUETOOTH_CONF_PATH}.save" ] && [ -f /usr/share/dbus-1/system.d/bluetooth.conf.save ]; then
        BLUETOOTH_CONF_PATH=/usr/share/dbus-1/system.d/bluetooth.conf
    fi
    if [ -f "${BLUETOOTH_CONF_PATH}.save" ]; then
        echo "Restoring ${BLUETOOTH_CONF_PATH}"
        mv "${BLUETOOTH_CONF_PATH}.save" "${BLUETOOTH_CONF_PATH}"
    fi
fi