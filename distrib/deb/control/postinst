case "$1" in
    configure)
        if [ -f /tmp/status ]; then
            STATUS=$(cat /tmp/status)
            rm /tmp/status
        else
            STATUS=install
        fi
        ;;
        
    abort-remove)
        echo "Uninstallation failed."
        exit 1
        ;;

    abort-upgrade)
        echo "Upgrade failed."
        exit 1
        ;;
        
    *)
        echo "postinst scripts called with unknown parameter $1"
        exit 1
        ;;
esac

if [ "${STATUS}" = "install" ]; then
    echo "Installing Kura bluetooth..."
    export TIMESTAMP=`date +%Y%m%d%H%M`
    export LOG=/tmp/kura_bluetooth_install_${TIMESTAMP}.log
    export PATH=$PATH:/usr/java/bin:/usr/bin/java/bin
    echo "Configuring Kura bluetooth..."

    bash /opt/eclipse/kura/.data/kura_bluetooth_install.sh 2>&1 | tee -a $LOG | systemd-cat -t Kura

    mkdir -p /opt/eclipse/kura/log
    mv $LOG /opt/eclipse/kura/log/

    if test -f /tmp/install_error; then
        echo "Kura networking installation failed. Please uninstall Kura bluetooth manually."
        rm /tmp/install_error
        exit 1
    fi

    echo "Kura bluetooth installation completed."
fi
