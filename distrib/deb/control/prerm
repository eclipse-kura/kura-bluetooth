if pgrep -x "java" > /dev/null; then
    /bin/systemctl stop kura> /dev/null 2>&1
fi
if [ -d /tmp/.kura/ ]; then
    rm -fr /tmp/.kura/ > /dev/null 2>&1
fi
echo ""
echo "Uninstalling Kura bluetooth..."
export TIMESTAMP=`date +%Y%m%d%H%M`
export LOG=/tmp/kura_bluetooth_uninstall_${TIMESTAMP}.log

bash /opt/eclipse/kura/.data/kura_bluetooth_uninstall.sh 2>&1 | tee -a $LOG | systemd-cat -t Kura

mkdir -p /opt/eclipse/kura/log
mv $LOG /opt/eclipse/kura/log/

echo "Kura bluetooth uninstallation completed."
